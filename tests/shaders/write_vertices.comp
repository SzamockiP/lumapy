#version 450
layout(local_size_x = 1) in;

// Writes the same fullscreen triangle fullscreen.vert emits, in the same
// order — front-facing under the pipeline default (cull BACK, CCW).
layout(std430, set = 0, binding = 0) buffer Verts {
    vec2 v[];
};

void main() {
    v[0] = vec2(-1.0, -1.0);
    v[1] = vec2(-1.0,  3.0);
    v[2] = vec2( 3.0, -1.0);
}
