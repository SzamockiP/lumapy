#version 450
layout(local_size_x = 64) in;

layout(std430, set = 0, binding = 0) buffer Data {
    float values[];
};

layout(set = 0, binding = 1) uniform Params {
    float scale;
};

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < values.length()) {
        values[i] *= scale;
    }
}
